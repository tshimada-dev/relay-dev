# Claude Code (claude コマンド) 用の設定例
# このファイルをsettings.yamlにコピーして使用してください
# cp config/settings-claude.yaml.example config/settings.yaml
#
# 【前提条件】
#   Claude Code を使うには Claude の契約または Anthropic Console アカウントが必要です。
#   Windows では Git for Windows が必要です。
#
# 【インストール・セットアップ】
#   1. Claude Code をインストール:
#      irm https://claude.ai/install.ps1 | iex
#   2. 認証:
#      claude auth login
#      または claude を起動して /login を実行
#
# 【インストール確認】
#   claude -v
#
# 【主要フラグの説明】
#   --dangerously-skip-permissions : 非対話実行で permission prompt を省略する
#   -p "プロンプト"                : 非対話モードでプロンプトを直接渡す（relay-dev が実行時に本文を付与）

cli:
  command: "claude"
  flags: "--dangerously-skip-permissions -p"
  implementer_command: ""  # 空欄 = command を使用
  implementer_flags: ""
  reviewer_command: ""     # 空欄 = command を使用
  reviewer_flags: ""

escalation:
  phase1_timeout_sec: 300
  phase2_timeout_sec: 600
  phase3_timeout_sec: 1200

watcher:
  poll_fallback_sec: 5
  debounce_ms: 300

terminal:
  type: wt

lock:
  retry_count: 30
  retry_delay_ms: 200
  timeout_sec: 300
  loop_guard_wait_sec: 1800

log:
  directory: logs
  max_size_mb: 10
  rotation_count: 5

paths:
  project_dir: ".."           # コード出力先ディレクトリ。空 = relay-dev ディレクトリ自身。".." = 親ディレクトリ
  design_file: "DESIGN.md"
  status_file: queue/status.yaml
  lock_file: queue/status.lock
  dashboard_file: dashboard.md
  task_file: tasks/task.md

human_review:
  enabled: true
  phases:
    - Phase3-1  # 設計書レビュー → ゲート: Phase4
    - Phase4-1  # タスク分解レビュー → ゲート: Phase5
    - Phase7    # PRレビュー → ゲート: Phase7-1
  prompt_message: "レビューが完了しました。出力を確認して判断してください:"
  options: |
    [y] 承認（推奨通り次のフェーズへ進む）
    [n] 却下（理由を入力して前のフェーズに戻る）
    [c] 条件付き承認（追加フィードバックを付与）
    [s] スキップ（今回のみ自動承認）
    [q] 終了（手動対応のためエージェントを停止）