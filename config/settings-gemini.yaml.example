# Gemini CLI (gemini コマンド) 用の設定例
# このファイルをsettings.yamlにコピーして使用してください
# cp config/settings-gemini.yaml.example config/settings.yaml
#
# 【インストール・セットアップ】
#   1. gemini CLI をインストール (Node.js 20+ が必要):
#      npm install -g @google/gemini-cli
#   2. 認証:
#      gemini を起動して Google ログインを完了する
#      または GEMINI_API_KEY / GOOGLE_API_KEY を設定する
#
# 【インストール確認】
#   gemini --version

cli:
  command: "gemini"        # 共通デフォルト（role別未設定時のフォールバック）
  flags: "-y -p"
  implementer_command: ""  # 空欄 = command を使用
  implementer_flags: ""
  reviewer_command: ""     # 空欄 = command を使用
  reviewer_flags: ""

execution:
  # `single` = 常に直列実行。
  # `auto` / `parallel` = task-scoped lane で task group 並列化を許可。
  mode: single
  # 1 attempt が長引いたときに provider process を再起動する秒数。
  restart_after_sec: 6000
  # timeout restart を何回まで追加で試すか。1 = 初回 + 1 retry。
  max_retries: 1
  # 並列化するときは 2 以上にする。
  max_parallel_jobs: 1
  # 1 worker だけの task group を作らない既定。
  allow_single_parallel_job: false

watcher:
  poll_fallback_sec: 5

lock:
  retry_count: 30
  retry_delay_ms: 200
  timeout_sec: 300

log:
  directory: logs
  max_size_mb: 10
  rotation_count: 5

paths:
  project_dir: ".."           # コード出力先ディレクトリ。空 = relay-dev ディレクトリ自身。".." = 親ディレクトリ
  design_file: "DESIGN.md"
  status_file: queue/status.yaml
  lock_file: queue/status.lock
  dashboard_file: dashboard.md
  task_file: tasks/task.md

human_review:
  enabled: false  # 完全自動で回す場合は false
  phases:
    - Phase3-1  # 設計書レビュー → ゲート: Phase4
    - Phase4-1  # タスク分解レビュー → ゲート: Phase5
    - Phase7    # PRレビュー → ゲート: Phase7-1
