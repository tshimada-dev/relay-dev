# GitHub Copilot CLI (copilot コマンド) 用の設定例
# このファイルをsettings.yamlにコピーして使用してください
# cp config/settings-copilot-cli.yaml.example config/settings.yaml
#
# 【前提条件】
#   GitHub Copilot サブスクリプション（Individual, Business, または Enterprise）が必要です。
#
# 【インストール・セットアップ】
#   1. copilot CLI をインストール (Node.js 22+ が必要):
#      npm install -g @github/copilot
#      または winget install GitHub.Copilot
#   2. 初回起動後に /login を実行するか、COPILOT_GITHUB_TOKEN / GH_TOKEN / GITHUB_TOKEN を設定
#
# 【インストール確認】
#   copilot --version
#
# 【主要フラグの説明】
#   --autopilot              : 各ステップで確認を求めずに自律実行するモード
#   --yolo                   : すべてのツール権限を自動許可（ファイル操作・コマンド実行等）
#   --max-autopilot-continues: autoplotモードで自律継続する最大回数（大きいほど長い作業が可能）
#   -p "プロンプト"           : 非対話モードでプロンプトを直接渡す（relay-dev が実行時に本文を付与）
#
# 【使用例1: すべての役割を copilot CLI で動かす】
#   cli.command: copilot
#   cli.flags: "--autopilot --yolo --max-autopilot-continues 30 -p"
#
# 【使用例2: 役割ごとにCLIを使い分ける（Multi-CLI）】
#   implementer_command: copilot
#   implementer_flags: "--autopilot --yolo --max-autopilot-continues 30 -p"
#   reviewer_command: gemini
#   reviewer_flags: "-y -p"

cli:
  command: "copilot"
  flags: "--autopilot --yolo --max-autopilot-continues 30 -p"
  implementer_command: ""  # 空欄 = command を使用
  implementer_flags: ""
  reviewer_command: ""     # 空欄 = command を使用
  reviewer_flags: ""

escalation:
  # copilot CLI は応答が比較的速いため、デフォルト値で問題ないことが多い
  # 複雑なPhase（Phase5 実装など）では phase3_timeout_sec を大きくすることを検討
  phase1_timeout_sec: 120
  phase2_timeout_sec: 300
  phase3_timeout_sec: 600

execution:
  # `single` = 常に直列実行。
  # `auto` / `parallel` = task-scoped lane で task group 並列化を許可。
  mode: single
  # 並列化するときは 2 以上にする。
  max_parallel_jobs: 1
  # 1 worker だけの task group を作らない既定。
  allow_single_parallel_job: false

watcher:
  poll_fallback_sec: 5

lock:
  retry_count: 30
  retry_delay_ms: 200
  timeout_sec: 300

log:
  directory: logs
  max_size_mb: 10
  rotation_count: 5

paths:
  project_dir: ".."           # コード出力先ディレクトリ。空 = relay-dev ディレクトリ自身。".." = 親ディレクトリ
  design_file: "DESIGN.md"
  status_file: queue/status.yaml
  lock_file: queue/status.lock
  dashboard_file: dashboard.md
  task_file: tasks/task.md

human_review:
  enabled: true
  phases:
    - Phase3-1  # 設計書レビュー → ゲート: Phase4
    - Phase4-1  # タスク分解レビュー → ゲート: Phase5
    - Phase7    # PRレビュー → ゲート: Phase7-1
