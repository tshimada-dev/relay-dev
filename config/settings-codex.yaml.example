# Codex CLI (codex コマンド) 用の設定例
# このファイルをsettings.yamlにコピーして使用してください
# cp config/settings-codex.yaml.example config/settings.yaml
#
# 【インストール・セットアップ】
#   1. Codex CLI をインストール:
#      npm install -g @openai/codex
#   2. 認証:
#      codex login
#
# 【インストール確認】
#   codex --version

cli:
  command: "codex"
  flags: "--ask-for-approval never --model gpt-5.4 exec --skip-git-repo-check --sandbox workspace-write"
  implementer_command: ""  # 空欄 = command を使用
  implementer_flags: ""
  reviewer_command: ""     # 空欄 = command を使用
  reviewer_flags: ""

escalation:
  phase1_timeout_sec: 300
  phase2_timeout_sec: 600
  phase3_timeout_sec: 1200

execution:
  # `single` = 常に直列実行。
  # `auto` / `parallel` = task-scoped lane で task group 並列化を許可。
  mode: single
  # 並列化するときは 2 以上にする。
  max_parallel_jobs: 1
  # 1 worker だけの task group を作らない既定。
  allow_single_parallel_job: false

watcher:
  poll_fallback_sec: 5

lock:
  retry_count: 30
  retry_delay_ms: 200
  timeout_sec: 300

log:
  directory: logs
  max_size_mb: 10
  rotation_count: 5

paths:
  project_dir: ".."           # コード出力先ディレクトリ。空 = relay-dev ディレクトリ自身。".." = 親ディレクトリ
  design_file: "DESIGN.md"
  status_file: queue/status.yaml
  lock_file: queue/status.lock
  dashboard_file: dashboard.md
  task_file: tasks/task.md

human_review:
  enabled: true
  phases:
    - Phase3-1  # 設計書レビュー → ゲート: Phase4
    - Phase4-1  # タスク分解レビュー → ゲート: Phase5
    - Phase7    # PRレビュー → ゲート: Phase7-1
